# Papyrus — Environment Variables
#
# Copy to .env and fill in your values.
# Only infrastructure settings use env vars. All other settings
# (SMTP, cloud OAuth, scanner, printer, OCR, etc.) are configured
# via the Settings UI and stored in the database.

# ── Required ──

# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password
PAPYRUS_DB_URL=postgresql+asyncpg://papyrus:${POSTGRES_PASSWORD}@localhost:5432/papyrus

# Fernet key for encrypting secrets at rest
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PAPYRUS_ENCRYPTION_KEY=

# Session secret
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PAPYRUS_SESSION_SECRET=

# Public URL (used for OIDC redirect URIs and webhook URLs)
PAPYRUS_BASE_URL=https://papyrus.example.com

# ── OIDC Authentication ──

PAPYRUS_OIDC_ISSUER=https://auth.example.com/application/o/papyrus/
PAPYRUS_OIDC_CLIENT_ID=
PAPYRUS_OIDC_CLIENT_SECRET=
# Scopes (add "groups" for group-based admin mapping)
PAPYRUS_OIDC_SCOPES=openid email profile groups
# Admin group name (users in this group get admin role; leave empty for first-user-is-admin)
PAPYRUS_OIDC_ADMIN_GROUP=papyrus-admins
# Claim name containing group list (Authentik/Keycloak: "groups")
PAPYRUS_OIDC_GROUPS_CLAIM=groups

# ── Optional ──

# Traefik hostname label (used in compose.yaml)
PAPYRUS_HOSTNAME=papyrus.example.com

# Development mode (auto-login without OIDC)
# PAPYRUS_DEV_MODE=false
