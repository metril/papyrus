# Database
PAPYRUS_DB_URL=postgresql+asyncpg://papyrus:secret@db:5432/papyrus

# OIDC Authentication (Authentik/Keycloak)
PAPYRUS_OIDC_ISSUER=https://auth.example.com/application/o/papyrus/
PAPYRUS_OIDC_CLIENT_ID=your-client-id
PAPYRUS_OIDC_CLIENT_SECRET=your-client-secret

# Printer
PAPYRUS_PRINTER_URI=ipp://192.168.1.100/ipp
PAPYRUS_PRINTER_NAME=Brother_DCP_L2540DW

# Scanner
PAPYRUS_SCANNER_DEVICE=airscan:w:Brother DCP-L2540DW

# Security
PAPYRUS_ENCRYPTION_KEY=generate-a-fernet-key
PAPYRUS_SESSION_SECRET=generate-a-random-secret

# Application
PAPYRUS_BASE_URL=https://papyrus.example.com
PAPYRUS_SCAN_DIR=/app/data/scans
PAPYRUS_UPLOAD_DIR=/app/data/uploads
PAPYRUS_MAX_UPLOAD_SIZE_MB=50
PAPYRUS_SCAN_RETENTION_DAYS=7

# SMTP (optional, configure via web UI)
# PAPYRUS_SMTP_HOST=smtp.example.com
# PAPYRUS_SMTP_PORT=587
# PAPYRUS_SMTP_USER=user@example.com
# PAPYRUS_SMTP_PASSWORD=password
# PAPYRUS_SMTP_FROM=papyrus@example.com

# PostgreSQL (for docker-compose)
POSTGRES_DB=papyrus
POSTGRES_USER=papyrus
POSTGRES_PASSWORD=secret
